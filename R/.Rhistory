library(lpSolveR)
devtools::document()
load("C:/Users/sutar/Documents/Y3Sem2/STA3005/lpSolveR/data/lp_example.rda")
library(testthat)
library(lpSolveR)
test_check("lpSolveR")
rm(list=ls())
devtools::load_all(".")
simplex_method(...)
sf <- lp_to_standard_form(c(2,3),
A_ub=matrix(c(1,1,2,1),2,T), b_ub=c(4,6))
sf$n_original    # 2
sf$n_slack       # 2
sf$n_artificial  # 0
dim(sf$A)        # 2 x 4
sf$variable_names
sf2 <- lp_to_standard_form(c(1,2),
A_eq=matrix(c(1,1),1), b_eq=3)
sf2$n_artificial  # 1
sf3 <- lp_to_standard_form(c(3,5),
A_ub=matrix(c(1,0,0,1),2,T), b_ub=c(4,6),
maximize=TRUE)
sf3$c[1:2]  # -3, -5
res <- simplex_method(c(2,3),
A_ub=matrix(c(1,1,2,1,0,1),3,T), b_ub=c(4,6,2),
maximize=TRUE)
res$status      # "optimal"
res$obj_value   # 10
res$solution    # x1=2, x2=2
res$iterations
res$tableau_history
res2 <- simplex_method(c(1,2),
A_ub=matrix(c(1,0,0,1),2,T), b_ub=c(3,3))
res2$obj_value  # 0 (at origin)
res3 <- simplex_method(c(-1,-1),
A_ub=matrix(c(-1,0,0,-1),2,T), b_ub=c(-1,-1))
res3$status  # "infeasible" or "unbounded"
res <- two_phase_simplex(c(1,2),
A_eq=matrix(c(1,1),1), b_eq=3)
res$status             # "optimal"
res$obj_value          # 3  (x1=3,x2=0)
res$phase1_iterations
res$phase2_iterations
res2 <- two_phase_simplex(c(1,1),
A_eq=matrix(c(1,1,1,1),2,T), b_eq=c(5,3))
res2$status  # "infeasible"
res3 <- two_phase_simplex(lp_example$obj,
A_ub=lp_example$A_ub, b_ub=lp_example$b_ub)
res3$status; res3$obj_value
res <- interior_point(c(2,3),
A_ub=matrix(c(1,1,2,1),2,T), b_ub=c(4,6))
res$status   # "optimal"
res$obj_value
res$duality_gap_history  # should decrease toward 0
tail(res$duality_gap_history, 1)  # near 0
r_ip <- interior_point(lp_example$obj,
lp_example$A_ub, lp_example$b_ub)
r_sp <- simplex_method(lp_example$obj,
lp_example$A_ub, lp_example$b_ub)
abs(r_ip$obj_value - r_sp$obj_value)  # < 1e-4
cmp <- compare_lp_methods(lp_example$obj,
lp_example$A_ub, lp_example$b_ub)
cmp$summary_df           # data.frame, 3 rows
names(cmp$summary_df)    # method, obj_value,
iterations, runtime_sec, status
cmp$results$simplex$solution
cmp$results$two_phase$phase1_iterations
cmp$results$interior_point$duality_gap_history
p <- plot_lp_feasible_region(
obj  = c(2,3),
A_ub = matrix(c(1,1,2,1,0,1),3,T),
b_ub = c(4,6,2),
xlim = c(0,6), ylim = c(0,6)
)
print(p)   # ggplot: shaded region, constraint lines,
red optimal point
class(p)   # "gg" "ggplot"
