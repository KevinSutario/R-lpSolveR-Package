> ### Name: lp_to_standard_form
> ### Title: Convert a General LP to Standard Form
> ### Aliases: lp_to_standard_form
> 
> ### ** Examples
> 
> obj   <- c(2, 3)
> A_ub  <- matrix(c(1, 1, 2, 1), nrow = 2, byrow = TRUE)
> b_ub  <- c(4, 6)
> sf    <- lp_to_standard_form(obj, A_ub, b_ub)
> sf$A
     [,1] [,2] [,3] [,4]
[1,]    1    1    1    0
[2,]    2    1    0    1
> sf$variable_names
